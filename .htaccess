<IfModule mod_expires.c>
    ExpiresActive On

    # Cache de imagens e ícones (1 ano)
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"

    # Cache de CSS, JavaScript e Fontes (1 mês)
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType font/woff2 "access plus 1 month"
</IfModule>

<IfModule mod_headers.c>
    <FilesMatch "\.(jpg|jpeg|png|gif|webp|svg|ico|woff2)$">
        Header set Cache-Control "max-age=31536000, public"
    </FilesMatch>
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "max-age=2592000, public"
    </FilesMatch>
</IfModule>

RewriteEngine On

# Remove index.html da raiz
RewriteRule ^index\.html$ / [R=301,L]
RewriteRule ^index$ / [R=301,L]

# Redireciona /alguma/pasta/index para /alguma/pasta
RewriteRule ^(.+)/index$ /$1 [R=301,L]

# Remove .html da URL e carrega o arquivo certo
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^(.+)$ $1.html [L]

# Redireciona arquivo.html → /arquivo
RewriteCond %{THE_REQUEST} "^[A-Z]{3,9}\ /([^ ]+)\.html\ "
RewriteRule ^ %1 [R=302,L]
